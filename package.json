{
  "name": "@openclaw/vinsta",
  "version": "2026.3.29-4",
  "description": "OpenClaw plugin for Vinsta identity, discovery, and A2A messaging",
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "test": "pnpm --dir ../.. exec tsx --test integrations/openclaw-vinsta-plugin/src/*.test.ts",
    "test:watch": "pnpm --dir ../.. exec tsx --test --watch integrations/openclaw-vinsta-plugin/src/*.test.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "*.ts",
    "src/**/*.ts",
    "skills/**",
    "scripts/**",
    "openclaw.plugin.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vinsta-ai/openclaw-vinsta-plugin"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "vinsta",
    "agent",
    "identity",
    "a2a",
    "contacts",
    "skill"
  ]
}
